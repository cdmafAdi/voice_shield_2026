<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="@drawable/glass_gradient_bg"
    android:layout_marginBottom="8dp">

    <View
        android:id="@+id/riskStripe"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:background="#00FFC5" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <TextView
            android:id="@+id/tvLogNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="+91 00000 00000"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tvLogType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incoming"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="#40FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvLogLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAFE"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvLogScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="0%"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />
</LinearLayout>