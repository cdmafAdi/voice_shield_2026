<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_marginTop="-280dp"
        android:background="@drawable/icon_sphere_bg"
        android:alpha="0.2"
        android:backgroundTint="#D8B4FE"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/homeHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/logoContainer"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:elevation="10dp"
            android:clipChildren="false">

            <ImageView
                android:id="@+id/shieldIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:scaleType="centerCrop"
                android:src="@drawable/logo7"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-75dp"
            android:fontFamily="sans-serif-black"
            android:text="VOICE SHIELD"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM ARMED &amp; SECURE"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.4"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/waveContainerFull"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@id/homeHeader" />

    <LinearLayout
        android:id="@+id/homeFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginBottom="15dp"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/waveContainerFull"
        app:layout_constraintVertical_bias="1.0">

        <FrameLayout
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:clipChildren="false">

            <View
                android:id="@+id/buttonGlowOuter"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:alpha="0.2"
                android:background="@drawable/button_glow_bg" />

            <View
                android:id="@+id/buttonGlow"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:alpha="0.6"
                android:background="@drawable/button_glow_bg" />

            <FrameLayout
                android:id="@+id/btnStartRound"
                android:layout_width="85dp"
                android:layout_height="85dp"
                android:layout_gravity="center"
                android:background="@drawable/premium_round_purple"
                android:backgroundTint="#D8B4FE"
                android:clickable="true"
                android:focusable="true"
                android:elevation="15dp">
                <ImageView
                    android:id="@+id/playIcon"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="4dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="#ffffff" />
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>