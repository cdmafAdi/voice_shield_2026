<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg">

    <View
        android:id="@+id/ambientGlowOrb"
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:background="@drawable/ambient_glow_orb"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_marginTop="-300dp"
        android:background="@drawable/icon_sphere_bg"
        android:alpha="0.15"
        android:backgroundTint="#D8B4FE"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBackPerm"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/glass_gradient_bg"
        android:elevation="8dp"
        android:padding="14dp"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/bottomActionArea"
        app:layout_constraintTop_toBottomOf="@id/btnBackPerm">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/permHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM PERIMETER"
                    android:textColor="#D8B4FE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.4"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/permTitleHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.04"
                    android:text="Initialize\nProtection"
                    android:textColor="#FFFFFF"
                    android:textSize="44sp"
                    android:lineHeight="48sp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="#D8B4FE"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/permSubTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:lineSpacingExtra="6dp"
                    android:text="To activate the real-time VoiceShield perimeter, the following system protocols must be initialized."
                    android:textColor="#99FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <include
                    android:id="@+id/cardMic"
                    layout="@layout/item_permission_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp" />

                <include
                    android:id="@+id/cardPhone"
                    layout="@layout/item_permission_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp" />

                <include
                    android:id="@+id/cardOverlay"
                    layout="@layout/item_permission_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomActionArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartProtection"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/btn_glow_purple"
            android:elevation="15dp"
            android:letterSpacing="0.25"
            android:stateListAnimator="@null"
            android:text="ACTIVATE SHIELD"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:alpha="0.4"
            android:enabled="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>