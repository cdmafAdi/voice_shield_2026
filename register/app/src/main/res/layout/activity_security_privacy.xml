<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg">

    <View
        android:id="@+id/ambientGlowOrb"
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:background="@drawable/ambient_glow_orb"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/glass_gradient_bg"
        android:elevation="8dp"
        android:padding="14dp"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/privacyScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toTopOf="@id/bottomActionArea">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEGAL PROTOCOL"
                android:textColor="#D8B4FE"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.4"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.04"
                android:lineHeight="48sp"
                android:text="Security &amp;\nPrivacy"
                android:textColor="#FFFFFF"
                android:textSize="48sp" />

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="#D8B4FE"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/subTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                android:lineSpacingExtra="8dp"
                android:text="Your digital identity is end-to-end encrypted. Review our shield guidelines to proceed."
                android:textColor="#B3FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-light" />

            <include android:id="@+id/item1" layout="@layout/item_security_feature" />
            <Space android:layout_width="match_parent" android:layout_height="28dp"/>
            <include android:id="@+id/item2" layout="@layout/item_security_feature" />
            <Space android:layout_width="match_parent" android:layout_height="28dp"/>
            <include android:id="@+id/item3" layout="@layout/item_security_feature" />
            <Space android:layout_width="match_parent" android:layout_height="28dp"/>
            <include android:id="@+id/item4" layout="@layout/item_security_feature" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomActionArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/checkContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_input_purple_glow"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/premium_round_outline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:text="I accept the Privacy Protocols"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAgree"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/btn_glow_purple"
            android:enabled="false"
            android:alpha="0.3"
            android:text="CONFIRM &amp; PROCEED"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>