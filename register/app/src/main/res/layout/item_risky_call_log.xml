<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="#131314"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp">

    <!-- Critical Alert Border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/glass_card_stroke"
        android:backgroundTint="#4DFF3B30"
        android:alpha="0.6" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageView
            android:id="@+id/riskIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="11dp"
            android:background="@drawable/bg_input_pill"
            android:backgroundTint="#1AFF3B30"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="#FF3B30"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@+id/scoreLayout"
            app:layout_constraintStart_toEndOf="@+id/riskIcon"
            app:layout_constraintTop_toTopOf="@+id/riskIcon"
            app:layout_constraintBottom_toBottomOf="@+id/riskIcon">

            <TextView
                android:id="@+id/tvLogNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="+91 00000 00000"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvLogLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spam Likely • Identity Theft"
                android:textColor="#80FFFFFF"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/scoreLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvLogScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="94%"
                android:textColor="#FF3B30"
                android:textSize="26sp" />
        </LinearLayout>

        <View
            android:id="@+id/diver"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="#12FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/riskIcon" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/diver">

            <androidx.cardview.widget.CardView
                android:id="@+id/btnNo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#00FFC5"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="1.5dp"
                    app:cardBackgroundColor="#131314"
                    app:cardCornerRadius="21dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="SAFE"
                        android:textColor="#00FFC5"
                        android:fontFamily="sans-serif-black"
                        android:textSize="12.5sp" />
                </androidx.cardview.widget.CardView>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnYes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="#FF3B30"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="BLOCK &amp; REPORT"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-black"
                    android:textSize="12sp" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>