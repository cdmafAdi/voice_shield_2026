<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#0D000000" />
            <padding android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:startColor="#33D8B4FE"
                android:centerColor="#264D00FF"
                android:endColor="#1A00FFC5"
                android:type="linear" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#4DFFFFFF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#B30F0F1E" />
        </shape>
    </item>

</layer-list>