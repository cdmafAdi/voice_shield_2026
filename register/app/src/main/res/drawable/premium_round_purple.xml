<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#6A1B9A" /> <size android:width="28dp" android:height="28dp" />
        </shape>
    </item>

    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#D8B4FE" /> <solid android:color="#40D8B4FE" /> </shape>
    </item>
</layer-list>