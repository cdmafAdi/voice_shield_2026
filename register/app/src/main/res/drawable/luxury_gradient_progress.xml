<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape
            android:shape="ring"
            android:thickness="14dp"
            android:useLevel="false">
            <solid android:color="#1AFFFFFF" /> </shape>
    </item>

    <item android:id="@android:id/progress">
        <rotate
            android:fromDegrees="0"
            android:toDegrees="360">
            <shape
                android:shape="ring"
                android:thickness="14dp"
                android:useLevel="true">
                <gradient
                    android:type="sweep"
                    android:startColor="#FF4B4B"
                    android:centerColor="#FFD700"
                    android:endColor="#00FFC5"
                    android:centerY="0.5"
                    android:centerX="0.5" />
                <stroke
                    android:width="1dp"
                    android:color="#4DFFFFFF" /> </shape>
        </rotate>
    </item>
</layer-list>